{
  "name": "coi-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate && node scripts/copy-pdf-worker.mjs",
    "db:push": "prisma db push",
    "db:phase3": "tsx --env-file=.env scripts/phase3-setup.ts",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "worker": "tsx --import ./instrumentation/worker.ts --env-file=.env scripts/worker.ts",
    "cron": "tsx --env-file=.env scripts/cron.ts",
    "cron:now": "tsx --env-file=.env scripts/cron.ts --run-now",
    "test:ops": "tsx --env-file=.env scripts/test-ops-features.ts",
    "test:dlq": "tsx --env-file=.env scripts/test-dlq.ts",
    "test:guardrails": "tsx scripts/test-guardrails.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@llamaindex/llama-cloud": "^2.10.0",
    "@openai/agents": "^0.12.0",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/instrumentation-openai": "^0.18.0",
    "@prisma/client": "^6.9.0",
    "@pydantic/logfire-node": "^0.18.3",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-scroll-area": "^1.2.13",
    "@radix-ui/react-slot": "^1.2.3",
    "@vercel/otel": "^2.1.3",
    "@x402/fetch": "^2.17.0",
    "agentmail": "^0.5.13",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.79.2",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.6.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "ioredis": "^5.11.1",
    "jose": "^6.0.11",
    "logfire": "^0.20.1",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "node-cron": "^4.6.0",
    "openai": "^6.45.0",
    "radix-ui": "^1.6.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.56.4",
    "react-pdf": "^10.4.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.21",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "prisma": "^6.9.0",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.22.5",
    "tw-animate-css": "^1.3.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
