generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum CoiStatus {
  PENDING_REVIEW
  ACCEPTED
  REJECTED
  EXPIRING_SOON
  EXPIRED
}

model CoiDocument {
  id                 String    @id @default(cuid())
  fileName           String
  cloudinaryUrl      String
  cloudinaryPublicId String
  mimeType           String
  fileSizeBytes      Int
  status             CoiStatus @default(PENDING_REVIEW)
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}
