# Copy to .env for local development. On Vercel, set these in Project → Environment Variables.
# See docs/VERCEL-DEPLOY.md and BACKGROUND_JOB_ARCHITECTURE.md.

# --- Core (required) ---
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
ADMIN_EMAIL=admin@example.com

# Local dev or Vercel: set ADMIN_PASSWORD (plain text is supported).
ADMIN_PASSWORD=your-password
# Optional: bcrypt hash instead of ADMIN_PASSWORD (if set, hash takes precedence)
# ADMIN_PASSWORD_HASH=

# Redis — rate limits, session revocation, cron lock, Redis DLQ only (NOT a job queue)
REDIS_URL=redis://localhost:6379
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Required in production (Vercel)
AGENTMAIL_WEBHOOK_SECRET=
HEALTH_CHECK_SECRET=

# --- Inngest (official SDK env vars) ---
# https://www.inngest.com/docs/sdk/environment-variables
# Local: set INNGEST_DEV=1 and run `npm run inngest:dev`
INNGEST_DEV=1
# Production (Vercel): set keys from Inngest Cloud dashboard
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
# INNGEST_SIGNING_KEY_FALLBACK=
# INNGEST_BASE_URL=
# INNGEST_ENV=
# INNGEST_SERVE_ORIGIN=
# INNGEST_SERVE_PATH=
# INNGEST_STREAMING=
# INNGEST_LOG_LEVEL=

# Job retries / Inngest flow control (optional)
JOB_MAX_ATTEMPTS=5
WORKER_COI_CONCURRENCY=2
WORKER_REMINDER_CONCURRENCY=3
REMINDER_EMAIL_RATE_LIMIT_MAX=100
REMINDER_EMAIL_RATE_LIMIT_MS=60000
CRON_SCHEDULE=0 9 * * *
REMINDER_DAYS_BEFORE=30,14,7,3
CRON_LOCK_TTL_SECONDS=1800

# --- Optional integrations ---
# AGENTMAIL_API_KEY=
# GROQ_API_KEY=
# LLAMA_CLOUD_API_KEY=
# LOGFIRE_TOKEN=

# --- Skeleton build (local only — do not commit a real token) ---
# 1. Log in at http://localhost:3000/login
# 2. Copy coi_session cookie from DevTools
# 3. Paste below, then: npm run bones:build
BONEYARD_SESSION_TOKEN=
