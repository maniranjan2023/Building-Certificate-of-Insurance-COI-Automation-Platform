# Copy to .env for local development. On Vercel, set these in Project → Environment Variables.
# See docs/VERCEL-DEPLOY.md for production checklist.

# --- Core (required) ---
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
ADMIN_EMAIL=admin@example.com

# Local dev or Vercel: set ADMIN_PASSWORD (plain text is supported).
ADMIN_PASSWORD=your-password
# Optional: bcrypt hash instead of ADMIN_PASSWORD (if set, hash takes precedence)
# ADMIN_PASSWORD_HASH=

REDIS_URL=redis://localhost:6379
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Required in production (Vercel)
AGENTMAIL_WEBHOOK_SECRET=
HEALTH_CHECK_SECRET=

# --- Optional integrations ---
# AGENTMAIL_API_KEY=
# GROQ_API_KEY=
# LLAMA_CLOUD_API_KEY=
# LOGFIRE_TOKEN=

# --- Skeleton build (local only — do not commit a real token) ---
# 1. Log in at http://localhost:3000/login
# 2. Copy coi_session cookie from DevTools
# 3. Paste below, then: npm run bones:build
BONEYARD_SESSION_TOKEN=
